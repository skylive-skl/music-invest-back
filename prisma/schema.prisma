generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ARTIST
  ADMIN
}

enum MediaType {
  AUDIO
  VIDEO
}

enum ProjectStatus {
  DRAFT
  FUNDING
  ACTIVE
  FAILED
  COMPLETED
}

model User {
  id              String       @id @default(uuid())
  email           String       @unique
  passwordHash    String
  role            Role         @default(USER)
  balance         Decimal      @default(0.0)
  
  projectsCreated Project[]    @relation("ArtistProjects")
  investments     Investment[]
  payouts         Payout[]
  withdrawals     Withdrawal[]
  
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model Project {
  id                  String       @id @default(uuid())
  title               String
  description         String
  artistId            String
  artist              User         @relation("ArtistProjects", fields: [artistId], references: [id])
  
  fundingGoal         Decimal
  currentFunding      Decimal      @default(0.0)
  revenueSharePercent Decimal
  durationMonths      Int
  
  coverImageUrl       String?
  
  status              ProjectStatus @default(DRAFT)
  
  investments         Investment[]
  revenueReports      RevenueReport[]
  mediaAttachments    MediaAttachment[]
  
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
}

model MediaAttachment {
  id        String    @id @default(uuid())
  projectId String
  project   Project   @relation(fields: [projectId], references: [id])
  url       String
  filename  String
  type      MediaType
  createdAt DateTime  @default(now())
}

model Investment {
  id           String   @id @default(uuid())
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id])
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  
  amount       Decimal
  sharePercent Decimal  @default(0.0)
  
  createdAt    DateTime @default(now())
}

model RevenueReport {
  id           String   @id @default(uuid())
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id])
  
  amount       Decimal
  periodStart  DateTime
  periodEnd    DateTime
  
  payouts      Payout[]
  
  createdAt    DateTime @default(now())
}

model Payout {
  id              String        @id @default(uuid())
  revenueReportId String
  revenueReport   RevenueReport @relation(fields: [revenueReportId], references: [id])
  userId          String
  user            User          @relation(fields: [userId], references: [id])
  
  amount          Decimal
  
  createdAt       DateTime      @default(now())
}

model Withdrawal {
  id              String        @id @default(uuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id])
  amount          Decimal
  status          String        @default("PENDING")
  
  createdAt       DateTime      @default(now())
}
